# Copy this file to .env and fill in your keys before running locally.
# In Vercel, add these in: Project → Settings → Environment Variables

# Anthropic Claude API — powers the Promptly AI chat widget
# Get your key at: https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_key_here

# Brevo (formerly Sendinblue) — email lead capture after 3 chat messages
# Get your key at: https://app.brevo.com/settings/keys/api
VITE_BREVO_API_KEY=your_key_here

# Canonical site URL — used for Open Graph and structured data
VITE_SITE_URL=https://www.getpromptly.co.uk
